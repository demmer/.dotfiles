User demmer
# Slack ~/.ssh/config
#
# If your SSH is broken, please post to #help-ssh.

# Things that should work:
# ssh aws-bastion.tinyspeck.com true ← connecting to a bastion, and then exiting without error, if there's an error then there's an issue 

IgnoreUnknown AddKeysToAgent,UseKeychain,WarnWeakCrypto

Include ~/.ssh/vscode_remote_config
Include ~/.ssh/dev_beaches
Include ~/.ssh/platform_specific
Include ~/.ssh/local_config

HashKnownHosts no
ServerAliveCountMax 4320
ServerAliveInterval 10
TCPKeepAlive no
WarnWeakCrypto no-pq-kex

Host *
  HashKnownHosts no
  ServerAliveInterval 10
  TCPKeepAlive no

# Dev shortnames already have ProxyCommands that construct the full hostname,
# so canonicalization just causes a costly config re-parse (doubling cassh exec).
Host dev? dev?? dev1??? dev2??? *-webapp-dev? *-webapp-dev?? *-webapp-dev1??? *-webapp-dev2???
  CanonicalizeHostname no

Host dev* qa*
  CanonicalizeHostname yes
  CanonicalDomains slack.com
  StrictHostKeyChecking no

Host qa*.slack.com
  ProxyCommand ssh -W %h.internal:%p aws-bastion.tinyspeck.com
  StrictHostKeyChecking no

Host dev*.slack.com
  ProxyCommand ssh -W %h.internal:%p aws-bastion.tinyspeck.com
  StrictHostKeyChecking no
  ForwardAgent yes
  AddKeysToAgent yes

Host *-webapp-dev? *-webapp-dev?? *-webapp-dev1??? *-webapp-dev2???
  ProxyCommand sh -c 'devid=$(echo %h | grep -oE "dev[0-9]+"); perl -e "alarm 5; exec @ARGV" ssh -O check aws-bastion.tinyspeck.com 2>/dev/null || rm -f /tmp/ssh-control-*@aws-bastion.tinyspeck.com:22; ssh -W $devid.slack.com.internal:%p aws-bastion.tinyspeck.com'
  StrictHostKeyChecking no
  ForwardAgent yes
  AddKeysToAgent yes

Host dev? dev?? dev1??? dev2???
  ProxyCommand ssh -W %h.slack.com.internal:%p aws-bastion.tinyspeck.com
  StrictHostKeyChecking no
  ForwardAgent yes
  AddKeysToAgent yes
#  IdentitiesOnly yes

Host vtgate-cli-gov-dev
  HostName %h.consul53.dev.private.govspeck.com

Host vtgate-cli-gov-prod
  HostName %h.consul53.prod.private.govspeck.com

# Shipyard hosts - bare hostnames ending in hex hash (no DNS exists for these).
# Resolves via Peekaboo API on the bastion and tunnels through.
#Match exec "echo '%h' | perl -ne 'exit 1 unless (m/^[a-z][a-z0-9-]+-[0-9a-f]{16,}$/)'"
#  CanonicalizeHostname no
#  ProxyCommand "${HOME}/.ssh/shipyard-ssh-proxy" %h %p

Host !*.* *
  CanonicalizeHostname yes
  CanonicalDomains nebula.tinyspeck.com ec2.tinyspeck.com

Host aws-bastion.prod.public.govspeck.com
  ProxyCommand "${HOME}/.ssh/ssm-ssh-proxy"

#SSM-DEV Host aws-bastion.dev.public.govspeck.com
#SSM-DEV   ProxyCommand "${HOME}/.ssh/ssm-ssh-proxy" --dev

Host aws-bastion*.tinyspeck.com bastion*.slack-sec.com *-bastion.dev.public.govspeck.com *-bastion.prod.public.govspeck.com
  ControlMaster auto
  ControlPath /tmp/ssh-control-%r@%h:%p
  ControlPersist 43200
  HostName %h
  ProxyCommand none
  SendEnv DUO_PASSCODE

Host *.tinyspeck.com slack-github.com *.slack-github.com *.slack.com ec2-* 10.*
  ProxyJump aws-bastion.tinyspeck.com

Host *.nebula.sandbox.private.govspeck.com *.nebula.dev.private.govspeck.com *.consul53.dev.private.govspeck.com
  ProxyJump aws-bastion.dev.public.govspeck.com

Host *.nebula.prod.private.govspeck.com *.consul53.prod.private.govspeck.com
  ProxyJump aws-bastion.prod.public.govspeck.com

