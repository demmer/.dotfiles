Host z-ops-* z-kube-beach-* z-ml-beach-*
  ForwardAgent yes

Host !*.* job-worker* www*
  HostName slack-%h

Host !*.* worker*
  HostName slack-job-%h

Host analytics staging-analytics-emr6-master.ec2.tinyspeck.com
  HostName staging-analytics-emr6-master.emr.nebula.tinyspeck.com
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null

# Play fast-and-loose with EC2-native hostnames.  This is admittedly slightly
# dangerous but we get IP addresses we've seen before so often that this is
# a pretty big productivity boost.
Host ec2-* ip-*
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
